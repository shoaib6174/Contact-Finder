# Required
GROQ_API_KEY=your_groq_key_here

# Optional but recommended
SERPER_API_KEY=your_serper_key_here

# Behavior knobs
REQUEST_DELAY=1.0
MAX_TOOL_CALLS=8
CONFIDENCE_THRESHOLD=0.7
# Use llama-3.1-8b-instant for cheaper development runs;
# switch to llama-3.3-70b-versatile for final reasoning if needed.
DEFAULT_MODEL=llama-3.1-8b-instant
